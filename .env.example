# .env.example - Commit this to Git
# Copy to .env and customize on Jetson

# Ollama - See JETSON_MODELS.md for details
OLLAMA_HOST=127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:3b-instruct  # RECOMMENDED for Jetson Orin NX 16GB (better grammar, speed, determinism)
# Available alternatives: llama3.2:3b (previous default), gemma2:2b (faster, lower quality)

# Audio
AUDIO_TEMP_DIR=/tmp/companion-audio
AUDIO_SAMPLE_RATE=16000
AUDIO_RECORD_SECONDS=5

# PyAudio device selection (for wake word detection)
# Use device name pattern for robust auto-detection across reboots/USB port changes
# Run 'python debug_audio_devices.py' to see available devices
AUDIO_DEVICE_NAME=PowerConf  # Auto-finds device matching this pattern (e.g., "PowerConf S3")

# ALSA recording device (run 'arecord -l' to see available devices)
AUDIO_INPUT_DEVICE=plughw:0,0  # Anker PowerConf S3 (card 0, device 0)

# PulseAudio playback device (run 'pactl list sinks short' to see available sinks)
AUDIO_OUTPUT_DEVICE=alsa_output.usb-Anker_PowerConf_S3_A3321-DEV-SN1-01.analog-stereo

# Storage (Simple JSONL for Phase 1-3)
# Default: ~/companion-data/conversations.jsonl
# Production: /mnt/nvme/companion/conversations.jsonl (requires permissions)
CONVERSATION_LOG=~/companion-data/conversations.jsonl
CONVERSATION_BUFFER_INTERVAL=300  # 5 minutes

# Conversation Context
CONVERSATION_CONTEXT_SIZE=20  # Last N exchanges to keep in memory

# Models
# NOTE: If you experience numpy conflicts, use 'small' instead of 'medium'
# See TROUBLESHOOTING_NUMPY.md for details
WHISPER_MODEL=small  # Options: tiny, base, small, medium (small recommended for Jetson)
TTS_MODEL=tts_models/en/ljspeech/vits  # Coqui TTS VITS model
USE_GPU=true  # Use GPU acceleration when available

# TTS Settings
# Convert bold markdown (**word**) to pauses for emphasis since VITS doesn't support prosody
TTS_PRESERVE_EMPHASIS=true  # true = "**that**" becomes ", that" (natural pause emphasis)

# Personality
# Choose which personality profile to use from personalities/ folder
# Options: casual_friend, patient_teacher, native_speaker, grammar_coach
PERSONALITY_PROFILE=grammar_coach

# Optional: SQLite (Phase 4+)
# CONVERSATION_DB=/mnt/nvme/companion/conversations.db

# Memory
MEMORY_WARNING_THRESHOLD=0.85
MEMORY_CRITICAL_THRESHOLD=0.95

# Thermal
THERMAL_WARNING_TEMP=70
THERMAL_CRITICAL_TEMP=80

# Logging
LOG_LEVEL=INFO
LOG_DIR=~/companion-data/logs
LOG_BUFFER_INTERVAL=300  # 5 minutes

# Zoo System (Epic 1)
ZOO_ENABLED=false  # Enable Zoo coaching system
ZOO_COACH_MODE=normal  # off | soft | normal
ZOO_DAILY_START=09:00
ZOO_DAILY_END=17:00

# Notion Integration (Epic 1 - Memory agents)
NOTION_API_KEY=  # Get from https://www.notion.so/my-integrations
NOTION_VOCAB_DB_ID=  # Notion database ID for vocabulary
NOTION_SYNC_INTERVAL_HOURS=24  # Sync once per day at startup

# Agent Tuning
ORCHESTRATOR_MAX_DRILLS_PER_MIN=1
FILLER_THRESHOLD_PER_MIN=3
TEMPO_MIN_WPM=100
TEMPO_MAX_WPM=180
GRAMMAR_SEVERITY_THRESHOLD=0.5

# Zoo Logging
ZOO_LOG_FLUSH_INTERVAL_SEC=300  # 5 minutes
ZOO_SESSION_BUFFER_SIZE=100

# MCP (optional - Phase 3+)
# MCP_SERVER_URL=http://localhost:8080

# Prometheus Metrics (optional)
# METRICS_PORT=8001
