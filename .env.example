# .env.example - Commit this to Git
# Copy to .env and customize on Jetson

# Ollama - See JETSON_MODELS.md for details
OLLAMA_HOST=127.0.0.1:11434
OLLAMA_MODEL=llama3.2:3b  # TESTED & RECOMMENDED for Jetson Orin NX 16GB
# Available alternatives: gemma2:2b (faster, lower quality), phi3:3.8b (untested)

# Audio
AUDIO_TEMP_DIR=/tmp/companion-audio
AUDIO_SAMPLE_RATE=16000
AUDIO_RECORD_SECONDS=5
# ALSA recording device (run 'arecord -l' to see available devices)
AUDIO_INPUT_DEVICE=plughw:0,0  # Anker PowerConf S3 (card 0, device 0)
# PulseAudio playback device (run 'pactl list sinks short' to see available sinks)
AUDIO_OUTPUT_DEVICE=alsa_output.usb-Anker_PowerConf_S3_A3321-DEV-SN1-01.analog-stereo

# Storage (Simple JSONL for Phase 1-3)
# Default: ~/companion-data/conversations.jsonl
# Production: /mnt/nvme/companion/conversations.jsonl (requires permissions)
CONVERSATION_LOG=~/companion-data/conversations.jsonl
CONVERSATION_BUFFER_INTERVAL=300  # 5 minutes

# Conversation Context
CONVERSATION_CONTEXT_SIZE=20  # Last N exchanges to keep in memory

# Models
WHISPER_MODEL=medium  # Options: tiny, base, small, medium (GPU recommended for medium)
TTS_MODEL=tts_models/en/ljspeech/vits  # Coqui TTS VITS model
USE_GPU=true  # Use GPU acceleration when available

# Optional: SQLite (Phase 4+)
# CONVERSATION_DB=/mnt/nvme/companion/conversations.db

# Memory
MEMORY_WARNING_THRESHOLD=0.85
MEMORY_CRITICAL_THRESHOLD=0.95

# Thermal
THERMAL_WARNING_TEMP=70
THERMAL_CRITICAL_TEMP=80

# Logging
LOG_LEVEL=INFO
LOG_DIR=~/companion-data/logs
LOG_BUFFER_INTERVAL=300  # 5 minutes

# MCP (optional - Phase 3+)
# MCP_SERVER_URL=http://localhost:8080

# Prometheus Metrics (optional)
# METRICS_PORT=8001
